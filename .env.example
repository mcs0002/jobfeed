# Copy to .env and adjust. Everything is optional for a first local run.

# Web app login. Required unless WEB_ALLOW_NO_AUTH=1 (localhost-only use).
# setup_web.sh generates both automatically if missing.
WEB_PASSWORD=
WEB_SECRET=

# Uncomment to run the web app without auth (only for localhost).
# WEB_ALLOW_NO_AUTH=1

# Path to the SQLite database (default: ./jobs.db).
# JOBS_DB=jobs.db

# Apply the strict function-level filter buckets at scrape time
# (default off: store broad, filter in the UI).
# JOBS_STRICT_FILTER=1

# selfcheck.py: also send failure alerts by email (needs notify.py configured).
# SELFCHECK_EMAIL=1

# ── notify.py (failure-alert emails) ────────────────────────────────────────
# All three must be set together for email alerts to work.

# Sender and recipient address for failure alerts.
# NOTIFY_EMAIL=you@example.com

# SMTP server hostname (SSL, port 465).
# SMTP_HOST=smtp.example.com

# SMTP password. On production (headless) hosts this must be in .env because
# launchd cannot unlock the login Keychain. On a dev Mac the Keychain fallback
# (SMTP_KEYCHAIN_SERVICE below) can be used instead.
# SMTP_PASSWORD=

# macOS Keychain service name for the SMTP password (dev Mac only; optional).
# Leave unset on headless/server hosts — Keychain lookup is disabled when empty.
# SMTP_KEYCHAIN_SERVICE=

# ── apply.py / cover_letter.py ──────────────────────────────────────────────
# SSH alias for the production host (used to fetch live job records).
# Defaults to "m1" if unset.
# M1_SSH=m1
